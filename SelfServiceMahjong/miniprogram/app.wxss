/* ========================================
   全局样式 —— 自助麻将馆 · 现代东方奢华
   主色：鎏金 #D4AF37  辅色：檀木红 #8B0000  底：暖白 #FBFAF7
   桌位状态色：玉绿 #4CAF50 / 朱红 #F44336 / 琥珀 #FF9800 / 墨灰 #9E9E9E
   ======================================== */

page {
  /* —— 调色板 —— */
  --color-primary: #D4AF37;
  --color-primary-dark: #B8960F;
  --color-primary-light: #F5E6B8;
  --color-accent: #8B0000;
  --color-accent-light: #C62828;
  --color-bg: #FBFAF7;
  --color-surface: #FFFDF7;
  --color-white: #FFFFFF;
  --color-text: #2C1810;
  --color-text-light: #5D4E37;
  --color-text-lighter: #8D7B6F;
  --color-text-muted: #B8A99A;
  --color-border: rgba(212,175,55,0.12);
  --color-border-light: #F0EBE3;
  --color-success: #4CAF50;
  --color-danger: #F44336;
  --color-warning: #FF9800;
  --color-disabled: #9E9E9E;

  /* —— 字号 —— */
  --font-size-xs: 20rpx;
  --font-size-sm: 24rpx;
  --font-size-base: 28rpx;
  --font-size-lg: 32rpx;
  --font-size-xl: 36rpx;
  --font-size-xxl: 42rpx;

  /* —— 间距 —— */
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-base: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 48rpx;

  /* —— 圆角 —— */
  --radius-sm: 6rpx;
  --radius-base: 12rpx;
  --radius-lg: 16rpx;

  /* —— 阴影 —— */
  --shadow-sm: 0 1px 6px rgba(139, 0, 0, 0.03);
  --shadow-card: 0 2px 16px rgba(139, 0, 0, 0.04);
  --shadow-lg: 0 4px 24px rgba(139, 0, 0, 0.06);

  /* —— 过渡 —— */
  --transition-fast: 0.15s ease;
  --transition-base: 0.25s cubic-bezier(0.4, 0, 0.2, 1);

  background-color: var(--color-bg);
  font-size: var(--font-size-base);
  color: var(--color-text);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  -webkit-font-smoothing: antialiased;
}

/* ========================================
   Flex 布局
   ======================================== */
.flex { display: flex; }
.flex-col { display: flex; flex-direction: column; }
.flex-center { display: flex; align-items: center; justify-content: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-wrap { flex-wrap: wrap; }
.flex-1 { flex: 1; }

/* 间距 */
.mt-xs { margin-top: var(--spacing-xs); }
.mt-sm { margin-top: var(--spacing-sm); }
.mt-base { margin-top: var(--spacing-base); }
.mt-lg { margin-top: var(--spacing-lg); }
.mb-sm { margin-bottom: var(--spacing-sm); }
.mb-base { margin-bottom: var(--spacing-base); }
.ml-sm { margin-left: var(--spacing-sm); }
.mr-sm { margin-right: var(--spacing-sm); }
.p-base { padding: var(--spacing-base); }
.p-lg { padding: var(--spacing-lg); }
.px-base { padding-left: var(--spacing-base); padding-right: var(--spacing-base); }
.py-base { padding-top: var(--spacing-base); padding-bottom: var(--spacing-base); }

/* 文字 */
.text-center { text-align: center; }
.text-right { text-align: right; }
.text-xs { font-size: var(--font-size-xs); }
.text-sm { font-size: var(--font-size-sm); }
.text-base { font-size: var(--font-size-base); }
.text-lg { font-size: var(--font-size-lg); }
.text-xl { font-size: var(--font-size-xl); }
.text-xxl { font-size: var(--font-size-xxl); }
.text-light { color: var(--color-text-light); }
.text-lighter { color: var(--color-text-lighter); }
.text-muted { color: var(--color-text-muted); }
.text-primary { color: var(--color-primary); }
.text-accent { color: var(--color-accent); }
.text-danger { color: var(--color-danger); }
.text-success { color: var(--color-success); }
.text-warning { color: var(--color-warning); }
.text-bold { font-weight: 600; }
.text-ellipsis { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

/* 背景 */
.bg-white { background-color: var(--color-white); }
.bg-primary { background-color: var(--color-primary); }
.bg-surface { background-color: var(--color-surface); }

/* ========================================
   卡片——东方奢华基底
   ======================================== */
.card {
  background: var(--color-surface);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  border: 1rpx solid var(--color-border);
}

/* ========================================
   按钮——鎏金体系
   ======================================== */
.btn {
  display: flex; align-items: center; justify-content: center;
  height: 88rpx; border-radius: var(--radius-base);
  font-size: var(--font-size-lg); font-weight: 600;
  border: none; outline: none; padding: 0 var(--spacing-lg);
  transition: all var(--transition-base); position: relative;
}
.btn::after { border: none; }

.btn-primary {
  background: linear-gradient(135deg, #D4AF37 0%, #B8960F 100%);
  color: #FFF; box-shadow: 0 4px 16px rgba(212,175,55,0.25);
}
.btn-primary:active { transform: scale(0.97); opacity: 0.9; }
.btn-primary[disabled] { background: #C8B89A; box-shadow: none; color: #FFF; }

.btn-outline {
  background: transparent; color: #8B6914;
  border: 2rpx solid rgba(212, 175, 55, 0.4);
}
.btn-outline:active { background: rgba(212,175,55,0.08); }

.btn-danger {
  background: linear-gradient(135deg, #F44336, #C62828);
  color: #FFF; box-shadow: 0 4px 12px rgba(244,67,54,0.2);
}
.btn-danger:active { transform: scale(0.97); }

.btn-sm { height: 64rpx; font-size: var(--font-size-base); padding: 0 var(--spacing-base); border-radius: 32rpx; }

/* ========================================
   状态指示器
   ======================================== */
.status-dot {
  display: inline-block; width: 14rpx; height: 14rpx;
  border-radius: 50%; margin-right: 8rpx;
}
.status-dot.idle { background: #4CAF50; box-shadow: 0 0 8px rgba(76,175,80,0.3); }
.status-dot.in_use { background: #F44336; box-shadow: 0 0 8px rgba(244,67,54,0.3); }
.status-dot.reserved { background: #FF9800; }
.status-dot.maintenance { background: #9E9E9E; }

.status-tag {
  display: inline-block; padding: 4rpx 14rpx; border-radius: 6rpx;
  font-size: var(--font-size-sm); color: #FFF; font-weight: 500;
}
.status-tag.pending { background: #FF9800; }
.status-tag.paid { background: #2196F3; }
.status-tag.using { background: #F44336; }
.status-tag.completed { background: #4CAF50; }
.status-tag.cancelled { background: #9E9E9E; }

/* ========================================
   空状态——淡雅留白
   ======================================== */
.empty-state {
  display: flex; flex-direction: column; align-items: center;
  justify-content: center; padding: 120rpx 0;
}
.empty-icon { width: 160rpx; height: 160rpx; margin-bottom: var(--spacing-base); opacity: 0.4; }
.empty-icon-text { font-size: 80rpx; margin-bottom: 16rpx; }
.empty-text { font-size: var(--font-size-base); color: var(--color-text-lighter); }
.empty-sub-text { font-size: var(--font-size-sm); margin-top: var(--spacing-xs); color: var(--color-text-muted); }

/* ========================================
   骨架屏——柔和呼吸
   ======================================== */
.skeleton {
  background: linear-gradient(110deg, #F0EBE3 30%, #E8E0D5 50%, #F0EBE3 70%);
  background-size: 200% 100%;
  animation: skeleton-shimmer 1.8s ease-in-out infinite;
  border-radius: var(--radius-sm);
}

@keyframes skeleton-shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* ========================================
   全局微交互
   ======================================== */

/* 页面切换淡入 */
@keyframes pageFadeIn {
  from { opacity: 0; transform: translateY(12rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 卡片入场 */
@keyframes cardSlideUp {
  from { opacity: 0; transform: translateY(24rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* ========================================
   分割线
   ======================================== */
.divider { height: 1rpx; background-color: var(--color-border); margin: var(--spacing-sm) 0; }

/* ========================================
   安全区域
   ======================================== */
.safe-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}
