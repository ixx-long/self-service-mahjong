/* 首页 */
.page { min-height: 100vh; padding-top: 12rpx; }

.skeleton-card { padding: 0 24rpx; margin-bottom: 8rpx; }

/* 门店入场动画 */
.store-item-wrapper {
  animation: cardFadeIn 0.5s cubic-bezier(0.4, 0, 0.2, 1) both;
}

@keyframes cardFadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.empty-icon-text { font-size: 80rpx; margin-bottom: 16rpx; }
