<!--系统设置-->
<view class="page" wx:if="{{!showEdit}}">
  <view class="admin-bar">
    <text class="admin-bar-icon">⚙️</text>
    <text class="admin-bar-title">系统设置</text>
  </view>
  <view wx:if="{{loading}}" class="loading-container">
    <view class="skeleton" style="height:80rpx;width:92%;margin:12rpx auto;" wx:for="{{[1,2,3,4,5]}}" wx:key="*this"></view>
  </view>

  <block wx:else>
    <view class="list" style="padding:0 20rpx;">
      <view wx:for="{{settings}}" wx:key="_id" class="setting-item flex-between" data-key="{{item.key}}" data-value="{{item.value}}" bindtap="onEdit">
        <view>
          <text class="text-bold">{{item.key}}</text>
          <text class="text-sm text-light" style="display:block;margin-top:8rpx;">{{item.description || ''}}</text>
        </view>
        <view class="flex" style="align-items:center;">
          <text class="text-sm text-primary" style="margin-right:12rpx;">{{item.displayValue}}</text>
          <text class="text-lighter">编辑 →</text>
        </view>
      </view>
    </view>
  </block>
</view>

<!-- ===== 编辑弹窗（根层级） ===== -->
<view wx:if="{{showEdit}}" class="modal-root">
  <view class="modal-mask" bindtap="onCloseEdit"></view>
  <view class="modal-box" catchtap="">
    <text class="modal-title">编辑 {{editingKey}}</text>
    <textarea class="edit-textarea" value="{{editingValue}}" bindinput="onValueInput" placeholder="请输入新值（数组/对象用 JSON 格式）" auto-height maxlength="5000"/>
    <view class="modal-btns">
      <button class="btn btn-outline" style="flex:1;" bindtap="onCloseEdit">取消</button>
      <button class="btn btn-primary" style="flex:2;margin:0;" bindtap="onSave">保存</button>
    </view>
  </view>
</view>
