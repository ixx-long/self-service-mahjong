/* 系统设置 — 暗色专业主题 */
.page {
  min-height: 100vh;
  background: #0F1923;
}

/* 管理员身份条 */
.admin-bar {
  background: linear-gradient(135deg, #162B3C 0%, #0F1923 100%);
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  border-bottom: 2rpx solid rgba(0, 198, 255, 0.15);
}
.admin-bar-icon { font-size: 36rpx; margin-right: 16rpx; }
.admin-bar-title { font-size: 30rpx; font-weight: bold; color: #00C6FF; letter-spacing: 2rpx; }

/* 设置列表 */
.list { padding: 0 20rpx; }
.setting-item {
  background: #1A2736;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(255,255,255,0.04);
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.setting-item:active { background: #233044; }
.setting-item .text-bold { color: #E8EDF2; }
.setting-item .text-light { color: #60758A; }
.setting-item .text-primary { color: #00C6FF; }
.setting-item .text-lighter { color: #40556A; }

/* 弹窗——根层级 */
.modal-root {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
}
.modal-mask {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.7);
}
.modal-box {
  position: relative;
  z-index: 1;
  width: 640rpx;
  background: #1A2736;
  border-radius: 20rpx;
  padding: 40rpx;
  border: 1rpx solid rgba(0, 198, 255, 0.15);
}
.modal-title {
  display: block;
  text-align: center;
  font-size: 34rpx;
  font-weight: bold;
  color: #E8EDF2;
  margin-bottom: 28rpx;
}
.modal-btns {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
}

.edit-textarea {
  width: 100%;
  min-height: 200rpx;
  background: #0F1923;
  border: 2rpx solid rgba(255,255,255,0.08);
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #E8EDF2;
  box-sizing: border-box;
}

.btn-outline {
  background: transparent !important;
  border: 2rpx solid #00C6FF !important;
  color: #00C6FF !important;
}
.btn-primary {
  background: linear-gradient(135deg, #00C6FF, #0090FF) !important;
  color: #0F1923 !important;
  border: none !important;
  font-weight: bold !important;
  border-radius: 12rpx !important;
}

.empty-state { text-align: center; padding: 80rpx 0; color: #40556A; }
.loading-container { padding-top: 40rpx; }
.skeleton {
  background: linear-gradient(90deg, #1A2736 25%, #233044 50%, #1A2736 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 16rpx;
}
@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}
