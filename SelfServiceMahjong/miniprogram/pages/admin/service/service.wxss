/* 客服管理 — 暗色专业主题 */
.page {
  min-height: 100vh;
  background: #0F1923;
  display: flex;
  flex-direction: column;
}

/* 管理员身份条 */
.admin-bar {
  background: linear-gradient(135deg, #162B3C 0%, #0F1923 100%);
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  border-bottom: 2rpx solid rgba(0, 198, 255, 0.15);
}
.admin-bar-icon { font-size: 36rpx; margin-right: 16rpx; }
.admin-bar-title { font-size: 30rpx; font-weight: bold; color: #00C6FF; letter-spacing: 2rpx; }

/* 会话列表 */
.session-item {
  background: #1A2736;
  border-radius: 16rpx;
  padding: 28rpx;
  margin: 16rpx 20rpx;
  border: 1rpx solid rgba(255,255,255,0.04);
}
.session-item:active { background: #233044; }
.session-item .text-bold { color: #E8EDF2; }
.session-item .text-light { color: #60758A; }
.session-item .text-lighter { color: #40556A; }

/* 聊天头部 */
.chat-header {
  background: #1A2736;
  padding: 20rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid rgba(0, 198, 255, 0.1);
}
.chat-header .text-primary { color: #00C6FF; }
.chat-header .text-bold { color: #E8EDF2; }

/* 聊天区域 */
.chat-area {
  flex: 1;
  padding: 24rpx;
  overflow-y: auto;
  background: #0F1923;
}

.msg-wrapper {
  display: flex;
  align-items: flex-start;
  margin-bottom: 28rpx;
}
.msg-left { flex-direction: row; }
.msg-right { flex-direction: row-reverse; }

.msg-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #1A2736;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin: 0 12rpx;
  font-size: 20rpx;
  color: #60758A;
  border: 1rpx solid rgba(255,255,255,0.06);
}

.msg-bubble {
  max-width: 70%;
  padding: 18rpx 24rpx;
  border-radius: 16rpx;
}
.bubble-left {
  background: #1A2736;
  border-top-left-radius: 4rpx;
}
.bubble-right {
  background: #00C6FF;
  border-top-right-radius: 4rpx;
}

.msg-text { font-size: 28rpx; line-height: 1.6; word-break: break-all; color: #E8EDF2; }
.msg-right .msg-text { color: #0F1923; font-weight: 500; }

.msg-image { max-width: 300rpx; border-radius: 12rpx; }

.msg-time {
  display: block;
  font-size: 20rpx;
  margin-top: 6rpx;
  color: #40556A;
}
.msg-right .msg-time { color: rgba(15, 25, 35, 0.6); }

/* 输入栏 */
.input-bar {
  padding: 16rpx 24rpx;
  background: #1A2736;
  border-top: 1rpx solid rgba(0, 198, 255, 0.1);
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.chat-input {
  height: 64rpx;
  background: #0F1923;
  border-radius: 32rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  color: #E8EDF2;
  flex: 1;
}

.btn-primary {
  background: linear-gradient(135deg, #00C6FF, #0090FF) !important;
  color: #0F1923 !important;
  border: none !important;
  font-weight: bold !important;
  border-radius: 12rpx !important;
}

.empty-state { text-align: center; padding: 80rpx 0; color: #40556A; }
.loading-container { padding-top: 40rpx; }
.skeleton {
  background: linear-gradient(90deg, #1A2736 25%, #233044 50%, #1A2736 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 16rpx;
}
@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}
