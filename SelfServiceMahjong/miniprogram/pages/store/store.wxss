/* 门店详情页——现代东方奢华 */
.page { min-height: 100vh; padding-bottom: 120rpx; background: #FBFAF7; }

/* 门店头部卡片 */
.store-hero {
  margin: 20rpx 24rpx;
  background: linear-gradient(160deg, #FFFDF7 0%, #FFF9EB 100%);
  border-radius: 16rpx;
  border: 1rpx solid rgba(212,175,55,0.15);
  box-shadow: 0 2px 20rpx rgba(139,0,0,0.04);
  overflow: hidden;
}

.hero-content { padding: 28rpx 32rpx; }

.hero-top {
  display: flex; align-items: center; justify-content: space-between; margin-bottom: 16rpx;
}

.hero-name { font-size: 38rpx; font-weight: bold; color: #2C1810; letter-spacing: 2rpx; }

.rating-badge {
  display: flex; align-items: center; gap: 4rpx;
  background: rgba(212,175,55,0.1); padding: 6rpx 14rpx; border-radius: 20rpx;
}

.rating-star { color: #FFB800; font-size: 24rpx; }
.rating-num { font-size: 28rpx; font-weight: bold; color: #8B6914; }
.rating-count { font-size: 22rpx; color: #B8A070; }

.hero-address { font-size: 26rpx; color: #8D7B6F; display: block; margin-bottom: 16rpx; }

.hero-footer { display: flex; align-items: center; justify-content: space-between; }

.hero-hours { font-size: 24rpx; color: #B8A99A; }
.hero-phone { font-size: 24rpx; color: #D4AF37; font-weight: 500; }
.hero-nav { font-size: 24rpx; color: #4A90D9; font-weight: 500; }

/* 日期选择器——优化 */
.date-bar {
  display: flex; white-space: nowrap;
  padding: 16rpx 24rpx; background: #FFFDF7;
  border-bottom: 1rpx solid rgba(212,175,55,0.1);
}

.date-item {
  display: inline-flex; align-items: center; justify-content: center;
  min-width: 120rpx; height: 60rpx; padding: 0 20rpx; margin-right: 12rpx;
  border-radius: 30rpx; background: #F5F0E8;
  font-size: 26rpx; color: #8D7B6F; transition: all 0.25s ease;
}

.date-item.active {
  background: linear-gradient(135deg, #D4AF37, #B8960F);
  color: #FFF; font-weight: bold;
  box-shadow: 0 4px 12rpx rgba(212,175,55,0.3);
  transform: scale(1.05);
}

/* 底部栏——优化 */
.bottom-bar {
  position: fixed; left: 0; right: 0; bottom: 0;
  display: flex; align-items: center; height: 100rpx;
  background: #FFFDF7; border-top: 1rpx solid rgba(212,175,55,0.12);
  box-shadow: 0 -2px 16rpx rgba(139,0,0,0.04); z-index: 100;
}

.selected-hint { font-size: 26rpx; color: #5D4E37; }
.hint-highlight { color: #D4AF37; font-weight: bold; }
.hint-placeholder { font-size: 26rpx; color: #C8B89A; }

.btn-primary-bar {
  height: 100rpx; min-width: 240rpx; border: none; outline: none;
  background: linear-gradient(135deg, #D4AF37, #B8960F);
  color: #FFF; font-size: 32rpx; font-weight: bold;
  display: flex; align-items: center; justify-content: center;
  padding: 0 48rpx; border-radius: 0;
}

.btn-primary-bar::after { border: none; }

.btn-primary-bar.disabled { background: #C8B89A; }

.empty-icon-text { font-size: 80rpx; margin-bottom: 16rpx; }
