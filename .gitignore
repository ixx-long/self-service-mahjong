# 微信小程序云开发项目

# 依赖
node_modules/
miniprogram_npm/

# 云函数依赖（云端安装，不提交）
cloudfunctions/*/node_modules/

# 本地私有配置（每人不同，含AppID）
project.config.json
project.private.config.json

# 系统文件
.DS_Store
Thumbs.db
*.swp
*.swo

# 日志
*.log
npm-debug.log*

# 编辑器
.vscode/
.idea/

# 临时文件
*.tmp
*.temp

# 云开发本地调试（含敏感信息）
.cloudbase/
.claude/
