.page { display: flex; flex-direction: column; height: 100vh; background: var(--color-bg); }
.chat-area { flex: 1; padding: var(--spacing-base); overflow-y: auto; }

/* 消息行 */
.msg-wrapper { display: flex; align-items: flex-start; margin-bottom: var(--spacing-lg); }
.msg-left { flex-direction: row; }
.msg-right { flex-direction: row-reverse; }

.msg-avatar {
  width: 60rpx; height: 60rpx; border-radius: 50%; background: var(--color-bg);
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  margin: 0 var(--spacing-sm);
}

.msg-bubble { max-width: 70%; padding: var(--spacing-sm) var(--spacing-base); border-radius: var(--radius-base); }
.bubble-left { background: #fff; border-top-left-radius: 4rpx; }
.bubble-right { background: var(--color-primary); color: #fff; border-top-right-radius: 4rpx; }

.msg-text { font-size: var(--font-size-base); line-height: 1.6; word-break: break-all; }
.msg-right .msg-text { color: #fff; }
.msg-image { max-width: 300rpx; border-radius: var(--radius-sm); }
.msg-time { display: block; font-size: 20rpx; margin-top: 4rpx; }
.msg-right .msg-time { color: rgba(255,255,255,0.7); }

/* 输入栏 */
.input-bar { padding: var(--spacing-sm) var(--spacing-base); background: #fff; border-top: 1rpx solid var(--color-border); align-items: center; }
.btn-icon { font-size: 40rpx; padding: 0 var(--spacing-sm); }
.chat-input { height: 64rpx; background: var(--color-bg); border-radius: 32rpx; padding: 0 var(--spacing-base); font-size: var(--font-size-base); margin: 0 var(--spacing-sm); }
