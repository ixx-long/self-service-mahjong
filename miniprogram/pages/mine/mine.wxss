/* 个人中心样式 */

.page {
  min-height: 100vh;
  background-color: var(--color-bg);
}

/* 用户头部 */
.user-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-xl) var(--spacing-lg);
  padding-top: 80rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  background-color: var(--color-bg);
}

.avatar-placeholder {
  background-color: rgba(255,255,255,0.3);
}

.nickname {
  text-shadow: 0 1px 2px rgba(0, 0, 0, 0.1);
}

.role-tag {
  background-color: var(--color-white);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

/* 余额卡片 */
.balance-card {
  margin: -30rpx var(--spacing-base) var(--spacing-sm);
  padding: var(--spacing-lg);
  position: relative;
  z-index: 1;
}

/* 功能菜单 */
.menu-card {
  margin: var(--spacing-sm) var(--spacing-base);
  padding: 0;
}

.menu-item {
  padding: var(--spacing-lg);
}

.menu-item:active {
  background-color: #FAFAFA;
}

/* 退出登录 */
.logout-btn {
  display: flex;
  justify-content: center;
  padding: var(--spacing-lg);
}

/* 弹窗——根层级固定定位 */
.modal-root {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background-color: rgba(0, 0, 0, 0.55);
}

.modal-box {
  position: relative;
  z-index: 1;
  width: 560rpx;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 48rpx 40rpx 32rpx;
}

.modal-title {
  display: block;
  text-align: center;
  font-size: 34rpx;
  font-weight: bold;
  margin-bottom: 32rpx;
  color: #2C1810;
}

.modal-input {
  height: 88rpx;
  border: 2rpx solid #E5E5E5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 32rpx;
  text-align: center;
  width: 100%;
  box-sizing: border-box;
  background: #F9F9F9;
}

.modal-btns {
  display: flex;
  gap: 16rpx;
  margin-top: 32rpx;
}
