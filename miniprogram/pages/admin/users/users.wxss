/* 用户管理 — 暗色专业主题 */
.page {
  min-height: 100vh;
  background: #0F1923;
}

/* 管理员身份条 */
.admin-bar {
  background: linear-gradient(135deg, #162B3C 0%, #0F1923 100%);
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  border-bottom: 2rpx solid rgba(0, 198, 255, 0.15);
}
.admin-bar-icon { font-size: 36rpx; margin-right: 16rpx; }
.admin-bar-title { font-size: 30rpx; font-weight: bold; color: #00C6FF; letter-spacing: 2rpx; }

/* 搜索栏 */
.search-bar {
  background: #1A2736;
  padding: 20rpx 32rpx;
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid rgba(255,255,255,0.04);
}
.search-input {
  height: 64rpx;
  background: #0F1923;
  border-radius: 32rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  color: #E8EDF2;
  flex: 1;
}

/* 用户列表 */
.list { padding: 0 20rpx; }
.list-card {
  background: #1A2736;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(255,255,255,0.04);
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.list-card .text-bold { color: #E8EDF2; }
.list-card .text-light { color: #60758A; }
.list-card .text-lighter { color: #40556A; }
.list-card .text-primary { color: #00C6FF; }
.list-card .text-danger { color: #FF4757; }

.btn-outline {
  background: transparent !important;
  border: 2rpx solid #00C6FF !important;
  color: #00C6FF !important;
}
.btn-danger {
  background: rgba(255, 71, 87, 0.15) !important;
  border: 2rpx solid #FF4757 !important;
  color: #FF4757 !important;
}
.btn-sm {
  height: 52rpx !important;
  line-height: 52rpx !important;
  font-size: 24rpx !important;
  padding: 0 20rpx !important;
}
.btn-primary {
  background: linear-gradient(135deg, #00C6FF, #0090FF) !important;
  color: #0F1923 !important;
  border: none !important;
  font-weight: bold !important;
  border-radius: 12rpx !important;
}

.load-more text { color: #00C6FF; }
.empty-state { text-align: center; padding: 80rpx 0; color: #40556A; }
.loading-container { padding-top: 40rpx; }
.skeleton {
  background: linear-gradient(90deg, #1A2736 25%, #233044 50%, #1A2736 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 16rpx;
}
@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}
