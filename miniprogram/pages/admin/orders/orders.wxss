/* 订单管理 — 暗色专业主题 */
.page {
  min-height: 100vh;
  background: #0F1923;
  padding-bottom: 40rpx;
}

/* 管理员身份条 */
.admin-bar {
  background: linear-gradient(135deg, #162B3C 0%, #0F1923 100%);
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  border-bottom: 2rpx solid rgba(0, 198, 255, 0.15);
}
.admin-bar-icon { font-size: 36rpx; margin-right: 16rpx; }
.admin-bar-title { font-size: 30rpx; font-weight: bold; color: #00C6FF; letter-spacing: 2rpx; }

/* 筛选栏 */
.filter-bar {
  background: #1A2736;
  padding: 20rpx 32rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.04);
}
.picker-display {
  padding: 16rpx 24rpx;
  border: 2rpx solid rgba(0, 198, 255, 0.2);
  border-radius: 12rpx;
  color: #00C6FF;
  font-size: 28rpx;
  text-align: center;
}

/* 状态筛选滚动条 */
.status-filter {
  display: flex;
  white-space: nowrap;
  padding: 20rpx 24rpx;
  background: #0F1923;
}
.status-item {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 28rpx;
  margin-right: 12rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #60758A;
  background: #1A2736;
}
.status-item.active {
  background: #00C6FF;
  color: #0F1923;
  font-weight: bold;
}

/* 订单列表 */
.list { padding: 0 20rpx; }
.list-card {
  background: #1A2736;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(255,255,255,0.04);
}
.list-card .text-bold { color: #E8EDF2; }
.list-card .text-light { color: #60758A; }

/* 状态标签 */
.status-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-weight: bold;
}
.status-tag.pending { background: rgba(255,184,0,0.15); color: #FFB800; }
.status-tag.paid { background: rgba(0,198,255,0.15); color: #00C6FF; }
.status-tag.using { background: rgba(0,230,118,0.15); color: #00E676; }
.status-tag.completed { background: rgba(96,117,138,0.2); color: #60758A; }
.status-tag.cancelled { background: rgba(255,71,87,0.15); color: #FF4757; }

/* 按钮 */
.btn-outline {
  background: transparent !important;
  border: 2rpx solid #00C6FF !important;
  color: #00C6FF !important;
}
.btn-danger {
  background: rgba(255, 71, 87, 0.15) !important;
  border: 2rpx solid #FF4757 !important;
  color: #FF4757 !important;
}
.btn-sm {
  height: 52rpx !important;
  line-height: 52rpx !important;
  font-size: 24rpx !important;
  padding: 0 20rpx !important;
}

.empty-state { text-align: center; padding: 80rpx 0; color: #40556A; }
.loading-container { padding-top: 40rpx; }
.skeleton {
  background: linear-gradient(90deg, #1A2736 25%, #233044 50%, #1A2736 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 16rpx;
}
@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}
