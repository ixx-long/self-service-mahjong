/* 桌位时段选择器 */

.table-card {
  margin: 0 24rpx 20rpx;
  padding: 28rpx;
  background: #FFFDF7;
  border-radius: 16rpx;
  border: 1rpx solid rgba(212,175,55,0.1);
  box-shadow: 0 2px 12px rgba(139,0,0,0.03);
  transition: all 0.25s ease;
}

/* 头部 */
.table-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.table-info { display: flex; align-items: baseline; gap: 12rpx; }

.table-no {
  font-size: 32rpx;
  color: #2C1810;
  letter-spacing: 1rpx;
}

.table-type {
  font-size: 24rpx;
  color: #8D7B6F;
  background: #F5F0E8;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.table-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.price-text {
  font-size: 28rpx;
  color: #8B0000;
  font-weight: 600;
}

.price-unit {
  font-size: 22rpx;
  font-weight: 400;
  color: #B8A99A;
}

/* 维修提示 */
.maintenance-notice {
  text-align: center;
  padding: 32rpx 16rpx;
  background: #F9F6F0;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #9E9E9E;
}

/* 时段网格 */
.slot-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.slot-item {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: calc(25% - 9rpx);
  min-width: 130rpx;
  min-height: 100rpx;
  padding: 18rpx 8rpx;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  background: #FBF9F4;
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
}

/* 空闲态 */
.slot-item.free {
  border-color: rgba(76,175,80,0.3);
  background: linear-gradient(135deg, #FBFFF9, #F6FDF6);
}

.slot-item.free:active {
  transform: scale(0.95);
  border-color: #4CAF50;
  background: rgba(76,175,80,0.08);
}

/* 选中态 */
.slot-item.free.selected {
  border-color: #D4AF37;
  background: linear-gradient(135deg, #FFFBF0, #FFF7DC);
  box-shadow: 0 0 16rpx rgba(212,175,55,0.2);
  transform: scale(1.02);
}

.slot-item.free.selected .slot-time {
  color: #8B6914;
}

/* 已预约 */
.slot-item.booked {
  border-color: #E8D5B0;
  background: #FDFAF4;
  opacity: 0.65;
}

/* 使用中 */
.slot-item.occupied {
  border-color: rgba(244,67,54,0.2);
  background: #FFF8F7;
  opacity: 0.65;
}

.slot-time {
  font-size: 24rpx;
  font-weight: 600;
  color: #3E362E;
  margin-bottom: 6rpx;
}

.slot-indicator {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.indicator-dot {
  width: 10rpx; height: 10rpx;
  border-radius: 50%;
}

.indicator-dot.free { background: #4CAF50; box-shadow: 0 0 6rpx rgba(76,175,80,0.3); }
.indicator-dot.booked { background: #D4AF37; }
.indicator-dot.occupied { background: #F44336; }
