/* 门店卡片——现代东方奢华 */

.store-card {
  margin: 16rpx 24rpx;
  padding: 28rpx 32rpx;
  background: #FFFDF7;
  border-radius: 16rpx;
  border: 1rpx solid rgba(212, 175, 55, 0.12);
  box-shadow: 0 2px 16px rgba(139, 0, 0, 0.04);
  transition: all 0.2s ease;
  position: relative;
  overflow: hidden;
}

/* 顶部金色细线装饰 */
.store-card::before {
  content: '';
  position: absolute;
  top: 0; left: 24rpx; right: 24rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(212,175,55,0.4), transparent);
}

.store-card:active {
  transform: scale(0.985);
  box-shadow: 0 1px 8px rgba(139, 0, 0, 0.06);
}

/* 头部 */
.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding-top: 8rpx;
}

.store-name-wrap {
  display: flex;
  align-items: center;
  max-width: 65%;
  gap: 8rpx;
}

.store-icon { font-size: 32rpx; }

.store-name {
  font-size: 34rpx;
  color: #2C1810;
  letter-spacing: 1rpx;
}

/* 距离徽章 */
.distance-badge {
  background: linear-gradient(135deg, rgba(212,175,55,0.15), rgba(212,175,55,0.08));
  padding: 6rpx 18rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(212, 175, 55, 0.2);
}

.distance-text {
  font-size: 24rpx;
  color: #8B6914;
  font-weight: 600;
}

/* 主体 */
.card-body {
  margin-bottom: 20rpx;
}

.address-text {
  font-size: 26rpx;
  color: #8D7B6F;
  display: block;
  margin-bottom: 6rpx;
}

.hours-text {
  font-size: 22rpx;
  color: #B8A99A;
}

/* 底部 */
.card-footer {
  border-top: 1rpx solid rgba(139,0,0,0.06);
  padding-top: 18rpx;
}

.status-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.status-indicator {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.status-pulse {
  width: 14rpx; height: 14rpx;
  border-radius: 50%;
}

.pulse-green {
  background: #4CAF50;
  box-shadow: 0 0 8rpx rgba(76,175,80,0.4);
  animation: pulse-glow 2s ease-in-out infinite;
}

.pulse-red {
  background: #F44336;
  box-shadow: 0 0 8rpx rgba(244,67,54,0.3);
}

@keyframes pulse-glow {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.6; }
}

.status-label {
  font-size: 26rpx;
  color: #5D4E37;
  font-weight: 500;
}

.has-free .status-label { color: #2E7D32; }
.full .status-label { color: #C62828; }

.arrow-icon {
  font-size: 36rpx;
  color: #C8B89A;
  font-weight: 300;
}

/* 容量进度条 */
.capacity-bar {
  margin-top: 12rpx;
  height: 6rpx;
  background: #F0EBE3;
  border-radius: 3rpx;
  overflow: hidden;
}

.capacity-fill {
  height: 100%;
  border-radius: 3rpx;
  transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1);
}

.capacity-fill.high { background: linear-gradient(90deg, #4CAF50, #66BB6A); }
.capacity-fill.low { background: linear-gradient(90deg, #FF9800, #FFB74D); }
.capacity-fill.none { background: #DDD; }
